# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas — replace user, password, and cluster host from Atlas Connect → Drivers
# If password contains special characters (@ # % etc.), URL-encode them (@ → %40)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/streammates?retryWrites=true&w=majority

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
